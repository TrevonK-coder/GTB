# GTB Intranet — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── M-Pesa Daraja API ────────────────────────────────────────────
# Get keys from: https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_PASSKEY=your_lipa_na_mpesa_passkey_here
MPESA_PAYBILL=522522
MPESA_TILL=5312847

# Set to 'false' to use production Daraja API (sandbox by default)
MPESA_SANDBOX=true

# Public URL where Safaricom will send payment callbacks
# Must be HTTPS. Use ngrok for local testing: ngrok http 8080
# e.g., MPESA_CALLBACK_URL=https://abc123.ngrok.io/api/mpesa/callback
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# ── Server ───────────────────────────────────────────────────────
PORT=8080
