{
  "buildCommand": "echo ''",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*\\.js)", "destination": "/$1" },
    { "source": "/(.*\\.css)", "destination": "/$1" },
    { "source": "/(.*\\.png)", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
